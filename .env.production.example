# Required for production
DATABASE_URL=postgresql://user:password@db-host:5432/ldm_steel?sslmode=require
NEXTAUTH_SECRET=change-me-to-a-long-random-secret
NEXTAUTH_URL=https://your-domain.example
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_CALLBACK_URL=https://your-domain.example/?paid
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# Optional OAuth providers
MAILRU_CLIENT_ID=
MAILRU_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Recommended for production monitoring
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ENABLE_DEV=0
SENTRY_DEBUG=0

# Recommended for production rate limiting (Upstash)
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=1 m
RATE_LIMIT_API_MAX=60
RATE_LIMIT_API_WINDOW=1 m

# Optional public API URL (must be a full URL if set)
NEXT_PUBLIC_API_URL=https://your-domain.example/api
