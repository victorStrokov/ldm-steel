generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id            Int            @id @default(autoincrement())
  name          String
  createdAt     DateTime       @default(now())
  users         User[]
  products      Product[]
  productRelations ProductRelatedProduct[]
  orders        Order[]
  inquiries     Inquiry[]
  inventory     Inventory[]
  inventoryLogs InventoryLog[]
  managerAssignments ManagerAssignment[]
  categories    Category[]
  settings      TenantSettings?
}

enum PriceMode {
  visible
  hidden
  request
}

enum CheckoutMode {
  order
  inquiry
}

model TenantSettings {
  id           Int          @id @default(autoincrement())
  tenantId     Int          @unique
  priceMode    PriceMode    @default(request)
  checkoutMode CheckoutMode @default(inquiry)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id                 Int               @id @default(autoincrement())
  fullName           String            @db.VarChar(150)
  email              String            @unique @db.VarChar(255)
  passwordHash       String?           @db.VarChar(100)
  role               UserRole          @default(USER)
  tenantId           Int
  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  verified           DateTime?
  provider           String?
  providerId         String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  cart               Cart?
  orders             Order[]
  verificationCode   VerificationCode?
  mustChangePassword Boolean           @default(false)
  sessions           Session[]
  activityLogs       ActivityLog[]
  banned             Boolean           @default(false)
  handlesAllCategories Boolean         @default(false)
  managedInquiries   Inquiry[]         @relation("InquiryManager")
  managerAssignments ManagerAssignment[]

  @@index([email])
}

model Session {
  id           String   @id @default(uuid())
  userId       Int
  refreshToken String   @unique
  userAgent    String?
  ip           String?
  deviceId     String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    String
  ip        String?
  userAgent String?

  requestId String?
  method    String?
  url       String?
  latencyMs Float?
  meta      String?

  createdAt DateTime @default(now())
}

model Category {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  name      String
  slug      String   @unique
  parentId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id])
  children Category[] @relation("CategoryParent")
  managerAssignments ManagerAssignment[]
  products Product[]
  tenant   Tenant     @relation(fields: [tenantId], references: [id])
}

model ManagerAssignment {
  id         Int      @id @default(autoincrement())
  userId     Int
  categoryId Int?
  productId  Int?
  tenantId   Int
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([categoryId])
  @@index([productId])
}

model Product {
  id         Int           @id @default(autoincrement())
  tenantId   Int
  name       String
  slug       String        @unique
  shortDesc  String?
  fullDesc   String?
  status     ProductStatus @default(ACTIVE)
  categoryId Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  category    Category       @relation(fields: [categoryId], references: [id])
  managerAssignments ManagerAssignment[]
  items       ProductItem[]
  images      ProductImage[]
  relatedProducts ProductRelatedProduct[] @relation("ProductRelatedOutgoing")
  relatedToProducts ProductRelatedProduct[] @relation("ProductRelatedIncoming")

  @@index([categoryId])
}

model ProductRelatedProduct {
  id                Int                @id @default(autoincrement())
  productId         Int
  relatedProductId  Int
  tenantId          Int
  kind              RelatedProductKind @default(RECOMMENDED)
  sortOrder         Int                @default(0)
  isRequired        Boolean            @default(false)
  compatibilityNote String?            @db.VarChar(500)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  product        Product @relation("ProductRelatedOutgoing", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("ProductRelatedIncoming", fields: [relatedProductId], references: [id], onDelete: Cascade)
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
  @@index([tenantId])
  @@index([productId, sortOrder])
  @@index([relatedProductId])
}

model ProductItem {
  id        Int      @id @default(autoincrement())
  productId Int
  sku       String   @unique
  price     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productColors    String[]
  sizeDisplay      String?
  widthDisplay     String?
  heightDisplay    String?
  lengthDisplay    String?
  thicknessDisplay String?
  materialDisplay  String?
  productMaterials ProductMaterial?
  productShape     Int?
  cartItem         CartItem[]       @relation("ProductItemToCartItem")
  inquiryItems     InquiryItem[]

  product   Product    @relation(fields: [productId], references: [id])
  inventory Inventory?

  @@index([productId])
}

model ProductImage {
  id        Int    @id @default(autoincrement())
  productId Int
  url       String
  key       String
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id])
}

model Inventory {
  id            Int            @id @default(autoincrement())
  productItemId Int            @unique
  quantity      Int            @default(0)
  tenantId      Int
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  productItem   ProductItem    @relation(fields: [productItemId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  logs          InventoryLog[]
  status        ProductStatus  @default(ACTIVE)

  @@index([tenantId])
  @@index([productItemId])
}

model InventoryLog {
  id            Int      @id @default(autoincrement())
  inventoryId   Int
  productItemId Int
  tenantId      Int
  userId        Int?
  change        Int
  oldQuantity   Int
  newQuantity   Int
  reason        String?
  requestId     String?
  createdAt     DateTime @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id])
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
}

model Cart {
  id          Int        @id @default(autoincrement())
  userId      Int?       @unique
  token       String     @unique
  totalAmount Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User?      @relation(fields: [userId], references: [id])
  items       CartItem[]

  @@index([userId])
}

model CartItem {
  id            Int          @id @default(autoincrement())
  cartId        Int
  productItemId Int
  quantity      Int          @default(1)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  cart          Cart         @relation(fields: [cartId], references: [id])
  productItem   ProductItem  @relation("ProductItemToCartItem", fields: [productItemId], references: [id])

  @@index([cartId])
  @@index([productItemId])
}

model Order {
  id          Int         @id @default(autoincrement())
  userId      Int?
  tenantId    Int
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  token       String
  totalAmount Int
  status      OrderStatus @default(PENDING)
  paymentId   String?
  items       Json
  fullName    String      @db.VarChar(150)
  email       String      @db.VarChar(255)
  phone       String      @db.VarChar(20)
  address     String      @db.VarChar(255)
  comment     String?     @db.VarChar(1000)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([phone])
  @@index([tenantId])
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  code      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime

  @@unique([userId, code])
}

model Story {
  id              Int         @id @default(autoincrement())
  previewImageUrl String
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  items           StoryItem[]
}

model StoryItem {
  id          Int      @id @default(autoincrement())
  storyId     Int
  sourceUrl   String
  type        String   @default("image") // "image" | "video"
  sortOrder   Int      @default(0)
  storageKey  String?
  mimeType    String?
  durationSec Int?
  createdAt   DateTime @default(now())
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, sortOrder])
}

enum OrderStatus {
  PENDING
  SUCCEEDED
  CANCELLED
}

enum UserRole {
  USER
  MANAGER
  ADMIN
}

enum ProductMaterial {
  STEEL
  PVC
  ALUMINIUM
  PLASTIC
  RUBBER
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

enum RelatedProductKind {
  RECOMMENDED
  ACCESSORY
  COMPATIBLE
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
}

enum InquiryRouteMode {
  UNASSIGNED
  UNIVERSAL
  FULL
  PARTIAL
  FALLBACK
}

model Inquiry {
  id        Int           @id @default(autoincrement())
  token     String
  fullName  String        @db.VarChar(150)
  email     String        @db.VarChar(255)
  phone     String        @db.VarChar(20)
  comment   String?       @db.VarChar(1000)
  managerComment String?  @db.VarChar(2000)
  status    InquiryStatus @default(NEW)
  managerId Int?
  lastContactAt DateTime?
  nextFollowUpAt DateTime?
  routeModeSnapshot InquiryRouteMode?
  routeCoveredCategoryIds Json?
  routeMissingCategoryIds Json?
  tenantId  Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  manager   User?         @relation("InquiryManager", fields: [managerId], references: [id])
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  items     InquiryItem[]

  @@index([tenantId])
  @@index([managerId])
  @@index([email])
}

model InquiryItem {
  id            Int         @id @default(autoincrement())
  inquiryId     Int
  productItemId Int
  quantity      Int         @default(1)
  createdAt     DateTime    @default(now())
  inquiry       Inquiry     @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  productItem   ProductItem @relation(fields: [productItemId], references: [id])

  @@index([inquiryId])
  @@index([productItemId])
}
