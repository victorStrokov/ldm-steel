generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                  Int                     @id @default(autoincrement())
  name                String
  isMain              Boolean                 @default(false)
  status              TenantStatus            @default(ACTIVE)
  createdAt           DateTime                @default(now())
  categories          Category[]
  inquiries           Inquiry[]
  managerTasks        InquiryManagerTask[]
  inventory           Inventory[]
  inventoryLogs       InventoryLog[]
  managerAssignments  ManagerAssignment[]
  managerAccesses     ManagerTenantAccess[]
  orders              Order[]
  fulfillmentProducts Product[]               @relation("ProductFulfillment")
  products            Product[]
  productRelations    ProductRelatedProduct[]
  settings            TenantSettings?
  users               User[]
}

model TenantSettings {
  id                 Int          @id @default(autoincrement())
  tenantId           Int          @unique
  priceMode          PriceMode    @default(request)
  checkoutMode       CheckoutMode @default(inquiry)
  notificationEmails String[]     @default([])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id                    Int                   @id @default(autoincrement())
  fullName              String                @db.VarChar(150)
  email                 String                @unique @db.VarChar(255)
  passwordHash          String?               @db.VarChar(100)
  role                  UserRole              @default(USER)
  tenantId              Int
  verified              DateTime?
  provider              String?
  providerId            String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  mustChangePassword    Boolean               @default(false)
  banned                Boolean               @default(false)
  handlesAllCategories  Boolean               @default(false)
  activityLogs          ActivityLog[]
  cart                  Cart?
  managedInquiries      Inquiry[]             @relation("InquiryManager")
  inquiryEventLogs      InquiryEventLog[]     @relation("EventLogActor")
  managerTasks          InquiryManagerTask[]  @relation("ManagerTasks")
  managerAssignments    ManagerAssignment[]
  managerTenantAccesses ManagerTenantAccess[]
  orders                Order[]
  sessions              Session[]
  tenant                Tenant                @relation(fields: [tenantId], references: [id])
  verificationCode      VerificationCode?

  @@index([email])
}

model Session {
  id           String   @id @default(uuid())
  userId       Int
  refreshToken String   @unique
  userAgent    String?
  ip           String?
  deviceId     String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  ip        String?
  userAgent String?
  requestId String?
  method    String?
  url       String?
  latencyMs Float?
  meta      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id                 Int                 @id @default(autoincrement())
  tenantId           Int
  name               String
  slug               String              @unique
  parentId           Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  parent             Category?           @relation("CategoryParent", fields: [parentId], references: [id])
  children           Category[]          @relation("CategoryParent")
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  managerAssignments ManagerAssignment[]
  products           Product[]
}

model ManagerAssignment {
  id         Int       @id @default(autoincrement())
  userId     Int
  categoryId Int?
  productId  Int?
  tenantId   Int
  isPrimary  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  product    Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([categoryId])
  @@index([productId])
}

model ManagerTenantAccess {
  id        Int      @id @default(autoincrement())
  userId    Int
  tenantId  Int
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

model Product {
  id                  Int                     @id @default(autoincrement())
  tenantId            Int
  fulfillmentTenantId Int?
  name                String
  slug                String                  @unique
  shortDesc           String?
  fullDesc            String?
  status              ProductStatus           @default(ACTIVE)
  categoryId          Int
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  managerAssignments  ManagerAssignment[]
  category            Category                @relation(fields: [categoryId], references: [id])
  fulfillmentTenant   Tenant?                 @relation("ProductFulfillment", fields: [fulfillmentTenantId], references: [id])
  tenant              Tenant                  @relation(fields: [tenantId], references: [id])
  images              ProductImage[]
  items               ProductItem[]
  relatedProducts     ProductRelatedProduct[] @relation("ProductRelatedOutgoing")
  relatedToProducts   ProductRelatedProduct[] @relation("ProductRelatedIncoming")

  @@index([categoryId])
}

model ProductRelatedProduct {
  id                Int                @id @default(autoincrement())
  productId         Int
  relatedProductId  Int
  tenantId          Int
  kind              RelatedProductKind @default(RECOMMENDED)
  sortOrder         Int                @default(0)
  isRequired        Boolean            @default(false)
  compatibilityNote String?            @db.VarChar(500)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  product           Product            @relation("ProductRelatedOutgoing", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct    Product            @relation("ProductRelatedIncoming", fields: [relatedProductId], references: [id], onDelete: Cascade)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
  @@index([tenantId])
  @@index([productId, sortOrder])
  @@index([relatedProductId])
}

model ProductItem {
  id               Int              @id @default(autoincrement())
  productId        Int
  sku              String           @unique
  price            Int
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  productColors    String[]
  sizeDisplay      String?
  widthDisplay     String?
  heightDisplay    String?
  lengthDisplay    String?
  thicknessDisplay String?
  materialDisplay  String?
  productMaterials ProductMaterial?
  productShape     Int?
  cartItem         CartItem[]       @relation("ProductItemToCartItem")
  inquiryItems     InquiryItem[]
  inventory        Inventory?
  product          Product          @relation(fields: [productId], references: [id])

  @@index([productId])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String
  key       String
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id])
}

model Inventory {
  id            Int            @id @default(autoincrement())
  productItemId Int            @unique
  quantity      Int            @default(0)
  tenantId      Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  status        ProductStatus  @default(ACTIVE)
  productItem   ProductItem    @relation(fields: [productItemId], references: [id])
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  logs          InventoryLog[]

  @@index([tenantId])
  @@index([productItemId])
}

model InventoryLog {
  id            Int       @id @default(autoincrement())
  inventoryId   Int
  productItemId Int
  tenantId      Int
  userId        Int?
  change        Int
  oldQuantity   Int
  newQuantity   Int
  reason        String?
  requestId     String?
  createdAt     DateTime  @default(now())
  inventory     Inventory @relation(fields: [inventoryId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
}

model Cart {
  id          Int        @id @default(autoincrement())
  userId      Int?       @unique
  token       String     @unique
  totalAmount Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User?      @relation(fields: [userId], references: [id])
  items       CartItem[]

  @@index([userId])
}

model CartItem {
  id            Int         @id @default(autoincrement())
  cartId        Int
  productItemId Int
  quantity      Int         @default(1)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cart          Cart        @relation(fields: [cartId], references: [id])
  productItem   ProductItem @relation("ProductItemToCartItem", fields: [productItemId], references: [id])

  @@index([cartId])
  @@index([productItemId])
}

model Order {
  id          Int         @id @default(autoincrement())
  userId      Int?
  tenantId    Int
  token       String
  totalAmount Int
  status      OrderStatus @default(PENDING)
  paymentId   String?
  items       Json
  fullName    String      @db.VarChar(150)
  email       String      @db.VarChar(255)
  phone       String      @db.VarChar(20)
  address     String      @db.VarChar(255)
  comment     String?     @db.VarChar(1000)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([phone])
  @@index([tenantId])
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  code      String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, code])
}

model Story {
  id              Int         @id @default(autoincrement())
  previewImageUrl String
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  items           StoryItem[]
}

model StoryItem {
  id          Int      @id @default(autoincrement())
  storyId     Int
  sourceUrl   String
  type        String   @default("image")
  sortOrder   Int      @default(0)
  storageKey  String?
  mimeType    String?
  durationSec Int?
  createdAt   DateTime @default(now())
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId, sortOrder])
}

model Inquiry {
  id                      Int                  @id @default(autoincrement())
  token                   String
  fullName                String               @db.VarChar(150)
  email                   String               @db.VarChar(255)
  phone                   String               @db.VarChar(20)
  comment                 String?              @db.VarChar(1000)
  managerComment          String?              @db.VarChar(2000)
  status                  InquiryStatus        @default(NEW)
  managerId               Int?
  lastContactAt           DateTime?
  nextFollowUpAt          DateTime?
  routeModeSnapshot       InquiryRouteMode?
  routeCoveredCategoryIds Json?
  routeMissingCategoryIds Json?
  routesSnapshot          Json?
  tenantId                Int
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  manager                 User?                @relation("InquiryManager", fields: [managerId], references: [id])
  tenant                  Tenant               @relation(fields: [tenantId], references: [id])
  eventLogs               InquiryEventLog[]
  items                   InquiryItem[]
  managerTasks            InquiryManagerTask[]

  @@index([tenantId])
  @@index([managerId])
  @@index([email])
}

model InquiryItem {
  id            Int         @id @default(autoincrement())
  inquiryId     Int
  productItemId Int
  quantity      Int         @default(1)
  createdAt     DateTime    @default(now())
  inquiry       Inquiry     @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  productItem   ProductItem @relation(fields: [productItemId], references: [id])

  @@index([inquiryId])
  @@index([productItemId])
}

model InquiryManagerTask {
  id            Int               @id @default(autoincrement())
  inquiryId     Int
  managerId     Int
  tenantId      Int
  status        TaskStatus        @default(NEW)
  acceptedAt    DateTime?
  respondedAt   DateTime?
  closedAt      DateTime?
  offeredAmount Decimal?          @db.Decimal(12, 2)
  finalAmount   Decimal?          @db.Decimal(12, 2)
  resultReason  String?           @db.VarChar(1000)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  eventLogs     InquiryEventLog[]
  inquiry       Inquiry           @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  manager       User              @relation("ManagerTasks", fields: [managerId], references: [id])
  tenant        Tenant            @relation(fields: [tenantId], references: [id])

  @@index([inquiryId])
  @@index([managerId])
  @@index([tenantId])
  @@index([status])
}

model InquiryEventLog {
  id        Int                 @id @default(autoincrement())
  inquiryId Int
  taskId    Int?
  actorId   Int?
  action    String              @db.VarChar(100)
  oldValue  String?             @db.VarChar(2000)
  newValue  String?             @db.VarChar(2000)
  createdAt DateTime            @default(now())
  actor     User?               @relation("EventLogActor", fields: [actorId], references: [id])
  inquiry   Inquiry             @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  task      InquiryManagerTask? @relation(fields: [taskId], references: [id])

  @@index([inquiryId])
  @@index([taskId])
  @@index([actorId])
}

enum PriceMode {
  visible
  hidden
  request
}

enum TenantStatus {
  ACTIVE
  ARCHIVED
}

enum CheckoutMode {
  order
  inquiry
}

enum OrderStatus {
  PENDING
  SUCCEEDED
  CANCELLED
}

enum UserRole {
  USER
  MANAGER
  ADMIN
}

enum ProductMaterial {
  STEEL
  PVC
  ALUMINIUM
  PLASTIC
  RUBBER
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

enum RelatedProductKind {
  RECOMMENDED
  ACCESSORY
  COMPATIBLE
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
}

enum TaskStatus {
  NEW
  ACCEPTED
  RESPONDED
  AGREED
  DECLINED
  CANCELLED
  LOST
}

enum InquiryRouteMode {
  UNASSIGNED
  UNIVERSAL
  FULL
  PARTIAL
  FALLBACK
}
