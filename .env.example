# Required
DATABASE_URL=postgresql://user:password@localhost:5432/ldm_steel?sslmode=disable
NEXTAUTH_SECRET=change-me-to-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-secret-key
YOOKASSA_CALLBACK_URL=http://localhost:3000/?paid
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# Optional OAuth providers
MAILRU_CLIENT_ID=
MAILRU_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Optional Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENABLE_DEV=0
SENTRY_DEBUG=0

# Optional Upstash rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=1 m
RATE_LIMIT_API_MAX=60
RATE_LIMIT_API_WINDOW=1 m

# Optional public API URL (must be a full URL if set)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
